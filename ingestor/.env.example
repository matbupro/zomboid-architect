# =============================================================================
# ingestor/.env — Configuration du moteur d'ingestion multi-format
# =============================================================================

# ChromaDB (serveur vectoriel)
CHROMA_HOST=http://host.docker.internal:8000

# Ollama (modèle d'embedding)
OLLAMA_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text

# Claude API (optionnel : pour descriptions vision d'images)
# CLAUDE_API_KEY=sk-your-claude-key-here

# Données (chemins relatifs au projet root)
DATA_ROOT=data

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Web crawling
MAX_WEB_DEPTH=5
MAX_WEB_PAGES=20
WEB_RATE_LIMIT=30
USER_AGENT=Zomboid Knowledge Engine (RAG multi-format)

# OCR
OCR_LANG=fra+eng
