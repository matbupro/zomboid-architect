# =============================================================================
# .env — Variables d'environnement du bot Discord Zomboid
# Copier ce fichier en .env et remplir les valeurs
# =============================================================================

# ------------------------------------------------------------------------------
# Discord
# ------------------------------------------------------------------------------
DISCORD_TOKEN=ton_token_discord_ici

# ------------------------------------------------------------------------------
# LLM Local (Ollama) — par défaut Ollama tourne sur la machine hôte
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2          # ou mistral, phi3, etc.
LLM_TEMPERATURE=0.7            # 0.0 = déterministe, 1.0 = créatif

# ------------------------------------------------------------------------------
# LLM Fallback (Claude API) — optionnel si tu as une clé Anthropic
# ------------------------------------------------------------------------------
# CLAUDE_API_KEY=sk-ant-api03-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ------------------------------------------------------------------------------
# Knowledge Engine (ChromaDB) — par défaut sur la machine hôte
# ------------------------------------------------------------------------------
CHROMA_HOST=http://host.docker.internal:8000

# ------------------------------------------------------------------------------
# Configuration du moteur d'embedding
# ------------------------------------------------------------------------------
ZOMBOID_EMBEDDING_MODEL=nomic-embed-text
