# Copier ce fichier en .env.notion et remplir les valeurs :
# 1. NOTION_API_KEY → token "ntn_xxx..." depuis notion.so/my-integrations
# 2. NOTION_DATABASE_ID → UUID de la base Notion (URL: notion.site/xxxxx-DATABASE_ID-yyyyy)

NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=00000000-0000-0000-0000-000000000000
