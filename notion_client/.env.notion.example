# ============================================================================
# NOTION API CONFIGURATION — TEMPLATE SÉCURISÉ
#
# ⚠️  JAMAIS committe le fichier .env.notion avec de vraies valeurs.
#     Ce fichier (.env.notion.example) est le SEUL template public dans Git.
#
# Setup (une seule fois) :
#   1. Copier : copy .env.notion.example .env.notion
#   2. Obtenir les identifiants : https://notion.so/my-integrations
#   3. Remplir les deux variables ci-dessous
#   4. Vérifier que .env.notion est ignoré par Git (git ls-files .env.notion)
#
# 🔒 En cas de fuite du token NOTION_API_KEY :
#   1. Aller sur https://notion.so/my-integrations
#   2. Cliquer sur l'intégration concernée
#   3. Régénérer le token immédiatement (l'ancien devient invalide)
#   4. Mettre à jour .env.notion localement
#   5. Vérifier le git log si un fichier a été commité accidentellement
# ============================================================================

# Internal Integration Token (commence par "ntn_")
# 🔒 SECRET — régénérer immédiatement en cas de fuite
NOTION_API_KEY=ntn_YOUR_TOKEN_HERE

# Database ID — 32 caractères UUID avec tirets
# Pas un secret, mais requis pour le fonctionnement
# Trouver l'ID : ouvrir la DB dans Notion → "..." → "Copy link to database"
# L'ID est dans l'URL entre les slashs
NOTION_DATABASE_ID=00000000-0000-0000-0000-000000000000
