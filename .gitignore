# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*
.env.*.local

# Data directories (contain runtime/generated data)
data/staging/*
data/production/*
data/workspace/*
data/tmp/*
data/sources/*
data/quarantine/*
data/raw/*
!data/staging/.gitkeep
!data/production/.gitkeep
!data/workspace/.gitkeep
!data/tmp/.gitkeep
!data/sources/.gitkeep
!data/quarantine/.gitkeep
!data/raw/.gitkeep

# Logs
*.log
logs/
!logs/.gitkeep

# Test output (full captures — files ignored, empty dir kept via .gitkeep)
.test_output/*.log
.test_output/*.raw
.test_output/*_run.ps1
!.test_output/.gitkeep

# Backups (manual/scheduled snapshots)
backups/manual/
backups/staging/
backups/production/

# Vector & local storage data dirs
db/staging/
db/production/
data/storage/

# Database brut — 10+ Go de donnees brutes, jamais committe
database/

# Database brut (source brute des donnees extraites — 10+ Go, jamais committe)
database/

# OS
.DS_Store
Thumbs.db

