# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.*.local

# Data directories (contain runtime/generated data)
data/staging/*
data/production/*
data/workspace/*
data/tmp/*
data/sources/*
data/quarantine/*
!data/staging/.gitkeep
!data/production/.gitkeep
!data/workspace/.gitkeep
!data/tmp/.gitkeep
!data/sources/.gitkeep
!data/quarantine/.gitkeep

# Logs
*.log
logs/
!logs/.gitkeep

# Backups (chromadb only; manual/scheduled snapshots may be tracked)
backups/chromadb/
!backups/chromadb/.gitkeep

# DB (ChromaDB persistence)
db/staging/
db/production/

# OS
.DS_Store
Thumbs.db

