# =============================================================================
# .env.example — Variables d'environnement du projet Zomboid_Architect
# =============================================================================
#
# Copier ce fichier en .env et remplir les valeurs marquées [OBLIGATOIRE].
# Les variables sans valeur par défaut doivent être remplies pour que le projet
# fonctionne correctement.
#
# Les modules suivants lisent automatiquement ce fichier au démarrage :
#   - bot/config.py          (chemin: bot/.env)
#   - ingestor/config.py    (chemin: ingestor/.env)
#
# IMPORTANT : Ce fichier n'est PAS commité dans .gitignore.
# Steam credentials (ingestor/.env) sont gérés séparément (voir Phase 7).
# Notion API key est gérée via notion_client/.env.notion (voir Phase 12).
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# REQUIS — Le bot ne démarre pas sans ces valeurs
# ──────────────────────────────────────────────────────────────────────────────

# Discord : token du bot (obligatoire, sans ce .env → sys.exit(1))
DISCORD_TOKEN=ton_token_discord_ici

# ──────────────────────────────────────────────────────────────────────────────
# Ollama (par défaut) — recommandé, fallback Claude API si absent
# ──────────────────────────────────────────────────────────────────────────────

# URL du serveur Ollama (défaut: http://host.docker.internal:11434)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Modèle par défaut pour les réponses (défaut: llama3.2, en prod: qwen3.6:35b-a3b)
OLLAMA_MODEL=qwen3.6:35b-a3b

# Température du LLM [0.0-1.0] (défaut: 0.7) — plus bas = plus déterministe
LLM_TEMPERATURE=0.7

# ──────────────────────────────────────────────────────────────────────────────
# Embedding / RAG — pour ChromaDB et l'ingestion
# ──────────────────────────────────────────────────────────────────────────────

# Modèle d'embedding (défaut: nomic-embed-text)
ZOMBOID_EMBEDDING_MODEL=nomic-embed-text

# URL du serveur ChromaDB (défaut: http://host.docker.internal:8000)
CHROMA_HOST=http://host.docker.internal:8000

# ──────────────────────────────────────────────────────────────────────────────
# Claude API (fallback LLM) — optionnel, utilisé si Ollama indisponible
# ──────────────────────────────────────────────────────────────────────────────

# Clé API Anthropic (optionnel : activée uniquement si définie)
# CLAUDE_API_KEY=sk-ant-api03-...

# Modèle Claude à utiliser en fallback (défaut: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────────────────────────────────────────────
# Ingestion — données, chunking et crawling
# ──────────────────────────────────────────────────────────────────────────────

# Racine des données (défaut: data/)
DATA_ROOT=data

# Taille des chunks de texte pour l'embedding (défaut: 512)
CHUNK_SIZE=512

# Chevauchement entre chunks en caractères (défaut: 64)
CHUNK_OVERLAP=64

# Profondeur max de crawl web depuis chaque seed URL (défaut: 5)
MAX_WEB_DEPTH=5

# Pages max par seed URL de crawl web (défaut: 50)
MAX_WEB_PAGES=50

# Délai entre requêtes web, en millisecondes (défaut: 30ms)
WEB_RATE_LIMIT=30

# User-Agent pour les requêtes web (défaut: "Zomboid Knowledge Engine (RAG multi-format)")
USER_AGENT=Zomboid Knowledge Engine (RAG multi-format)

# Langues OCR (défaut: fra+eng)
OCR_LANG=fra+eng

# ──────────────────────────────────────────────────────────────────────────────
# Discord Workspace — canal de rapport d'état du bot
# ──────────────────────────────────────────────────────────────────────────────

# Nom exact du canal workspace dans le serveur Discord (défaut: "💻 WORKSPACE Z-ARCHITECT")
WORKSPACE_CHANNEL_NAME="💻 WORKSPACE Z-ARCHITECT"

# ID du canal workspace (optionnel : si le nom ne match pas, utiliser l'ID)
# Résolu automatiquement au démarrage ; passer ici en override :
# WORKSPACE_CHANNEL_ID=1234567890123456789

# ID du serveur Discord (guild) — optionnel, aide la recherche de canal
# DISCORD_GUILD_ID=1234567890123456789

# ──────────────────────────────────────────────────────────────────────────────
# Optionnel — intégrations avancées
# ──────────────────────────────────────────────────────────────────────────────

# URL webhook pour POSTer le workspace report (ex: serveur interne)
# SYNC_HOOK_URL=https://ton-serveur.internal/webhook/zomboid

# Limite de caractères maximale pour les réponses du bot (défaut: 4000)
MAX_RESPONSE_LENGTH=4000

# ──────────────────────────────────────────────────────────────────────────────
# Steam / Workshop — credentials séparés dans ingestor/.env (Phase 7)
# ──────────────────────────────────────────────────────────────────────────────
# Ces credentials sont gérés dans ingestor/.env, pas ici :
#   STEAM_USER        → ranger_fleo (ex: ingester de mods SteamCMD)
#   STEAM_PASS        → mot de passe Steam
#   STEAM_WEB_API_KEY → clé API Steam Web pour lookup par tags
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Generation de mods (Phase 12) — modgen
# ──────────────────────────────────────────────────────────────────────────────

# Repertoire de sortie pour les mods generes (defaut: mods/)
MOD_OUTPUT_PATH=mods/

# Chemin des templates Jinja2 (defaut: src/modgen/templates/)
# MOD_TEMPLATES_PATH=src/modgen/templates/

