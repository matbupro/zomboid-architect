# =============================================================================
# .env — Variables d'environnement du projet Zomboid_Architect
# Copier ce fichier en .env et remplir les valeurs.
# Les modules bot/ et ingestor/ lisent automatiquement ce fichier au lancement.
# =============================================================================

# ------------------------------------------------------------------------------
# Discord (bot/)
# ------------------------------------------------------------------------------
DISCORD_TOKEN=ton_token_discord_ici

# ------------------------------------------------------------------------------
# LLM Local (Ollama) — par défaut sur la machine hôte
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
LLM_TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# LLM Fallback (Claude API) — optionnel
# ------------------------------------------------------------------------------
# CLAUDE_API_KEY=sk-ant-api03-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ------------------------------------------------------------------------------
# Knowledge Engine (ChromaDB)
# ------------------------------------------------------------------------------
CHROMA_HOST=http://host.docker.internal:8000

# ------------------------------------------------------------------------------
# Moteur d'embedding (ingestor/)
# ------------------------------------------------------------------------------
ZOMBOID_EMBEDDING_MODEL=nomic-embed-text

# ------------------------------------------------------------------------------
# Inggestion multi-format (ingestor/)
# ------------------------------------------------------------------------------
DATA_ROOT=data
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_WEB_DEPTH=5
MAX_WEB_PAGES=20
WEB_RATE_LIMIT=30
USER_AGENT=Zomboid Knowledge Engine (RAG multi-format)
OCR_LANG=fra+eng

# ------------------------------------------------------------------------------
# Channel workspace Discord
# ------------------------------------------------------------------------------
WORKSPACE_CHANNEL_NAME="💻 WORKSPACE Z-ARCHITECT"
WORKSPACE_CHANNEL_ID=  # optionnel — résolu automatiquement
